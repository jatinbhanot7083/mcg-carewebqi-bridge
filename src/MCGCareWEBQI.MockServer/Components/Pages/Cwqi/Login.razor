@page "/cwqi/login/{SessionId:guid}"
@inject McgSessionStore Store

<PageTitle>CareWebQI &mdash; Log In</PageTitle>

@if (_session is null)
{
    <div class="cwqi-card" style="max-width:560px; margin:48px auto;">
        <div class="cwqi-card-body" style="text-align:center;">
            <strong>Session expired.</strong>
            <p>Please re-launch from the calling application.</p>
        </div>
    </div>
}
else
{
    <div style="display:flex; gap:24px; padding-top:40px; max-width:780px; margin:0 auto;">
        <div class="cwqi-card" style="flex:1;">
            <div class="cwqi-card-body" style="text-align:center; padding:36px 32px;">
                <svg viewBox="0 0 40 40" fill="none" style="width:70px; height:70px;">
                    <path d="M6 34 C 8 14, 14 6, 22 4 C 14 16, 12 26, 10 34 Z" fill="#5fb15c" />
                    <path d="M14 36 C 16 18, 22 10, 30 8 C 22 20, 18 30, 16 36 Z" fill="#7fc97f" opacity="0.85" />
                    <path d="M22 38 C 24 20, 30 12, 38 10 C 30 22, 26 32, 24 38 Z" fill="#9fd99f" opacity="0.7" />
                </svg>
                <h2 style="color:#1565c0; margin:18px 0 6px 0; font-weight:700;">Log In</h2>
                <p style="color:#424242; margin:0 0 24px 0;">Select the button below to access guidelines.</p>
                <p style="color:#757575; font-size:0.85rem; margin:0 0 28px 0;">
                    In case of denied access, contact support at
                    <a href="mailto:mcgsupport@evokeconnect.com">mcgsupport@evokeconnect.com</a>.
                </p>
                <a class="mcg-btn" style="font-weight:600; text-decoration:none; display:inline-block;"
                   href="@($"cwqi/search/{SessionId}")">
                    Enter Documentation
                </a>
            </div>
        </div>
        <div style="width:240px; padding:18px 0 0 0; color:#3b7cb8; font-size:0.9rem;">
            <div style="font-weight:700; color:#1565c0; margin-bottom:8px;">EvokeConnect &times; MCG</div>
            <p style="margin:0 0 10px 0;">
                EvokeConnect integrates MCG&rsquo;s evidence-based clinical guidelines directly into the
                care management and utilization management workflow.
            </p>
            <p style="margin:0;">
                Clinicians document indications inside CareWebQI; results post back automatically to the
                originating EvokeConnect decision and authorization records.
            </p>
        </div>
    </div>
}

@code {
    [Parameter] public Guid SessionId { get; set; }
    private McgMockSession? _session;
    protected override void OnInitialized() => _session = Store.Get(SessionId);
}
