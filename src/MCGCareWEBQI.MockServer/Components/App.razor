@inject Microsoft.AspNetCore.Http.IHttpContextAccessor Ctx

@{
    // Honor X-Forwarded-Prefix when the mock is fronted by the bridge's reverse proxy
    // (dock-mode). Without this, Blazor's NavigationManager builds URLs relative to "/"
    // and breaks out of the proxied path, sending the iframe to a non-existent bridge route.
    var pathBase = Ctx.HttpContext?.Request.PathBase.Value ?? "";
    var baseHref = string.IsNullOrEmpty(pathBase) ? "/" : pathBase.TrimEnd('/') + "/";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@baseHref" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro:wght@400;600;700&family=Source+Serif+Pro:ital,wght@1,600;1,700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Symbols+Rounded" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="MCGCareWEBQI.MockServer.styles.css" />
    <style>
        /* --- Real-CareWebQI palette (matches actual MCG screenshots) --- */
        html, body { font-family: 'Source Sans Pro', Tahoma, Arial, sans-serif; background:#e8edf2; color:#212121; }
        code, pre  { font-family: 'JetBrains Mono', Consolas, monospace !important; }
        a { color:#1565c0; text-decoration:underline; }
        a:hover { color:#0d47a1; }

        /* Top brand header — MCG / CareWebQI wordmark */
        .cwqi-header { background:#ffffff; padding:14px 24px; border-bottom:2px solid #1565c0; display:flex; align-items:center; justify-content:space-between; }
        .cwqi-mark   { display:flex; align-items:center; gap:4px; }
        .cwqi-mark .leaves { width:38px; height:38px; }
        .cwqi-mark .mcg    { font-size:1.7rem; font-weight:700; color:#5fb15c; letter-spacing:-0.5px; line-height:1; }
        .cwqi-mark .cwqi   { font-family:'Source Serif Pro', Georgia, serif; font-style:italic; font-size:1.55rem; color:#1565c0; font-weight:700; margin-left:6px; }
        .cwqi-mark .tm     { font-size:0.55rem; color:#5fb15c; vertical-align:super; }
        .cwqi-mark .reg    { font-size:0.6rem; color:#1565c0; vertical-align:super; }

        /* "Enter Documentation" pill button right below header */
        .enter-doc-bar { background:#cfd8dc; padding:8px 24px; border-bottom:1px solid #b0bec5; }
        .enter-doc-btn {
            background:#ffffff; border:1px solid #455a64; padding:5px 14px;
            font-size:0.85rem; cursor:pointer; border-radius:0;
            box-shadow: 1px 1px 0 #b0bec5;
        }
        .enter-doc-btn:hover { background:#eceff1; }

        /* Blue user-info strip */
        .user-strip {
            background:#3b7cb8; color:#ffffff; padding:6px 18px;
            font-size:0.82rem; text-align:right;
        }
        .user-strip a { color:#ffffff; text-decoration:underline; }
        .user-strip .mcg-mini {
            float:right; color:#a5d6a7; font-weight:700; margin-left:12px;
            font-style:italic; font-size:0.9rem;
        }

        /* Breadcrumb */
        .breadcrumb { padding:8px 18px; color:#1565c0; font-size:0.95rem; }
        .breadcrumb a { color:#1565c0; }

        /* Light-blue card banner like MCG */
        .cwqi-card { background:#ffffff; border:1px solid #b6d4ec; margin:8px 0; }
        .cwqi-card-header {
            background:#cfe2f3; padding:8px 12px; font-weight:700; color:#212121;
            display:flex; align-items:center; gap:8px; border-bottom:1px solid #b6d4ec;
        }
        .cwqi-card-body { padding:12px 16px; }

        /* Section banner — green "Selections Made, Indications Met" */
        .selections-banner {
            background:#7fbf7f; color:#ffffff; padding:6px 14px;
            font-weight:700; font-size:0.92rem; letter-spacing:0.3px;
        }

        /* Light-blue table headers */
        table.cwqi-table { width:100%; border-collapse:collapse; font-size:0.9rem; }
        table.cwqi-table thead th {
            background:#5b9bd5; color:#ffffff; padding:7px 10px; text-align:left;
            font-weight:600; border:1px solid #4a89c4;
        }
        table.cwqi-table tbody td { padding:6px 10px; border:1px solid #e0e0e0; vertical-align:top; }
        table.cwqi-table tbody tr:nth-child(odd)  td { background:#ffffff; }
        table.cwqi-table tbody tr:nth-child(even) td { background:#f5f9fc; }

        /* Three-state evaluation circle */
        .eval-circle {
            display:inline-flex; align-items:center; justify-content:center;
            width:18px; height:18px; border-radius:50%; font-size:11px; font-weight:700;
            vertical-align:middle; margin-right:4px; border:1.5px solid currentColor;
        }
        .eval-circle.met       { background:#43a047; color:#ffffff; border-color:#2e7d32; }
        .eval-circle.notmet    { background:#e53935; color:#ffffff; border-color:#c62828; }
        .eval-circle.unset     { background:#ffffff; color:#757575; border-color:#9e9e9e; }
        .eval-circle.partial   { background:#ffffff; color:#1565c0; border-color:#1565c0; }

        /* Yellow note icon next to each criterion */
        .note-icon {
            display:inline-block; width:14px; height:16px; vertical-align:middle;
            background:#fff59d; border:1px solid #cfa600; border-radius:2px;
            margin-left:4px; cursor:pointer; position:relative;
        }
        .note-icon::after {
            content:''; position:absolute; top:0; right:0;
            border-top:5px solid #cfa600; border-left:5px solid transparent;
        }
        .note-icon.has-note { background:#ffd54f; }

        /* Reference letter footnote link */
        .ref-letter {
            display:inline-block; color:#1565c0; font-weight:600; text-decoration:underline;
            font-size:0.85rem; margin:0 1px; cursor:pointer;
        }
        .ref-letter::before { content:'['; }
        .ref-letter::after  { content:']'; }

        /* Count badge in parens (1) (2) (3) */
        .count-badge { color:#1565c0; text-decoration:underline; cursor:pointer; font-weight:600; margin:0 2px; }

        /* Tree row */
        .tree-row { padding:3px 0; display:flex; align-items:flex-start; gap:6px; font-size:0.95rem; line-height:1.5; }
        .tree-row .expander { color:#1565c0; cursor:pointer; user-select:none; font-family:monospace; width:14px; flex-shrink:0; }
        .tree-row .text-block { flex:1; }
        .tree-row .text-block .label.bold { font-weight:700; }
        .tree-children { margin-left:24px; }

        /* MCG-style raised buttons (Save / Cancel) */
        .mcg-btn {
            background:linear-gradient(#f5f5f5, #e0e0e0);
            border:1px solid #9e9e9e; padding:5px 28px; font-size:0.9rem;
            cursor:pointer; border-radius:2px; box-shadow:1px 1px 0 #bdbdbd;
            min-width:88px;
        }
        .mcg-btn:hover { background:linear-gradient(#fafafa, #eeeeee); }
        .mcg-btn:active { background:linear-gradient(#e0e0e0, #f5f5f5); }
        .mcg-btn-row { text-align:center; padding:14px 0; }

        /* Inline calculator widget */
        .calc-widget {
            display:inline-flex; align-items:center; gap:3px;
            background:#e3f2fd; border:1px solid #90caf9; padding:1px 6px;
            border-radius:2px; color:#1565c0; cursor:pointer; font-size:0.82rem;
            margin:0 2px;
        }

        /* Hyperlinked clinical terms */
        .clinical-term { color:#1565c0; text-decoration:underline; cursor:pointer; }
        .clinical-term::after { content:' \24D8'; font-size:0.85em; }

        /* Footer */
        .cwqi-footer {
            text-align:center; padding:18px 12px; font-size:0.75rem; color:#616161;
            border-top:1px dotted #b0bec5; margin-top:32px;
        }
    </style>
    <HeadOutlet />
</head>

<body>
    <Routes />
    <div id="components-reconnect-modal"></div>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
