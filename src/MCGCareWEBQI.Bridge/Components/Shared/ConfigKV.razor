@* Tiny key/value row used in the dark hero info card. *@
<div style="display:flex; justify-content:space-between; margin-top:6px; font-size:0.85rem;">
    <span style="color:#94a3b8;">@K</span>
    <span style="color:#e2e8f0; font-weight:600;">@V</span>
</div>

@code {
    [Parameter] public string K { get; set; } = "";
    [Parameter] public string V { get; set; } = "";
}
