@inherits LayoutComponentBase
@* GuidingCare-style chrome (top auth strip + tab strip + left side rail) used ONLY by the demo caller page. *@

<MudThemeProvider IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="gc-auth-strip">
    <span><strong>Auth ID</strong>1109SYY0F</span>
    <span><strong>Due Date</strong>N/A</span>
    <span><strong>Overall Status</strong>Pending</span>
    <span style="margin-left:auto; cursor:pointer;" class="material-symbols-rounded">open_in_full</span>
</div>

<div class="gc-app">
    <nav class="gc-sidenav">
        <a href="#" class="item"><span class="material-symbols-rounded">list_alt</span><span>Authorization List</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">dynamic_form</span><span>Dynamic Authorization Summary</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">history_edu</span><span>Activities</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">edit_note</span><span>Auth Entry</span></a>
        <a href="/demo" class="item active"><span class="material-symbols-rounded">fact_check</span><span>Decisions</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">sticky_note_2</span><span>Notes</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">folder</span><span>Documents</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">forum</span><span>Messages</span></a>
        <a href="#" class="item"><span class="material-symbols-rounded">help_center</span><span>Support Summary</span></a>
    </nav>

    <main class="gc-main">
        <div class="gc-tabstrip">
            <div class="gc-tab">
                <span>(1109SYY0F) Donald Charleston</span>
                <span class="close material-symbols-rounded" style="font-size:1rem;">close</span>
            </div>
            <div style="flex:1;"></div>
            <div style="padding:8px 10px; color:#64748b; font-size:0.78rem;">1 / 1</div>
        </div>

        <div class="gc-page">
            @Body
        </div>
    </main>
</div>
